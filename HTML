<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Prevention of Infection Committee at the Geneva Health Forum—connecting evidence, expertise and action to advance infection prevention and address antimicrobial resistance.">
  <title>Prevent Infections. Preserve Antibiotics. | PIC</title>
  <style>
    :root {
      --orange: #f89c49;
      --orange-dark: #d86d13;
      --orange-soft: #fff3e8;
      --black: #151515;
      --graphite: #3f3f3f;
      --muted: #6e6e6e;
      --line: #dedede;
      --soft: #f7f7f7;
      --white: #ffffff;
      --shadow: 0 20px 60px rgba(0, 0, 0, .08);
      --radius: 22px;
      --max: 1180px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      color: var(--black);
      background: var(--white);
      font-family: "Source Sans Pro", "Segoe UI", Arial, sans-serif;
      line-height: 1.55;
      overflow-x: hidden;
    }
    body.modal-open { overflow: hidden; }
    button, input { font: inherit; }
    a { color: inherit; }
    img { max-width: 100%; }
    section { scroll-margin-top: 90px; }
    .container { width: min(var(--max), calc(100% - 40px)); margin-inline: auto; }
    .section { padding: 88px 0; }
    .section--soft { background: var(--soft); }
    .skip-link {
      position: fixed;
      z-index: 999;
      left: 16px;
      top: -80px;
      padding: 10px 14px;
      color: var(--white);
      background: var(--black);
      border-radius: 8px;
      transition: top .2s ease;
    }
    .skip-link:focus { top: 16px; }

    .site-header {
      position: sticky;
      z-index: 100;
      top: 0;
      background: rgba(255, 255, 255, .96);
      border-top: 5px solid var(--orange);
      border-bottom: 1px solid var(--line);
      backdrop-filter: blur(14px);
    }
    .nav {
      min-height: 78px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }
    .logo-link { display: inline-flex; align-items: center; text-decoration: none; }
    .logo { width: 145px; height: auto; display: block; }
    .nav-links { display: flex; align-items: center; gap: 26px; }
    .nav-links a {
      position: relative;
      color: var(--graphite);
      font-size: .94rem;
      font-weight: 700;
      text-decoration: none;
    }
    .nav-links a::after {
      position: absolute;
      left: 0;
      bottom: -9px;
      width: 0;
      height: 3px;
      background: var(--orange);
      content: "";
      transition: width .2s ease;
    }
    .nav-links a:hover::after,
    .nav-links a:focus-visible::after { width: 100%; }
    .nav-links .nav-action {
      padding: 10px 16px;
      color: var(--black);
      border: 1px solid var(--black);
      border-radius: 999px;
    }
    .nav-links .nav-action::after { display: none; }
    .nav-links .nav-action:hover { color: var(--white); background: var(--black); }
    .menu-button {
      display: none;
      width: 44px;
      height: 44px;
      border: 1px solid var(--line);
      border-radius: 50%;
      color: var(--black);
      background: var(--white);
      cursor: pointer;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin: 0 0 16px;
      color: var(--orange-dark);
      font-size: .78rem;
      font-weight: 800;
      letter-spacing: .14em;
      text-transform: uppercase;
    }
    .eyebrow::before { width: 30px; height: 4px; background: var(--orange); content: ""; }
    .section-heading {
      max-width: 790px;
      margin: 0;
      font-size: clamp(2.15rem, 4.5vw, 4.1rem);
      line-height: 1.02;
      letter-spacing: -.045em;
    }
    .section-intro {
      max-width: 760px;
      margin: 18px 0 0;
      color: var(--muted);
      font-size: 1.1rem;
    }

    .hero {
      position: relative;
      isolation: isolate;
      min-height: 700px;
      display: grid;
      align-items: center;
      overflow: hidden;
      background: var(--white);
    }
    .hero::before {
      position: absolute;
      z-index: -1;
      width: 540px;
      height: 540px;
      right: -245px;
      top: -190px;
      border: 110px solid var(--orange-soft);
      border-radius: 50%;
      content: "";
    }
    .hero::after {
      position: absolute;
      z-index: -1;
      width: 180px;
      height: 18px;
      right: 9%;
      bottom: 62px;
      background: var(--orange);
      content: "";
    }
    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.18fr) minmax(320px, .82fr);
      gap: clamp(50px, 7vw, 96px);
      align-items: center;
      padding: 88px 0 82px;
    }
    .hero h1 {
      max-width: 800px;
      margin: 0;
      font-size: clamp(4rem, 8vw, 7.5rem);
      line-height: .88;
      letter-spacing: -.072em;
    }
    .hero h1 span { display: block; color: var(--orange-dark); }
    .hero-lead {
      max-width: 710px;
      margin: 28px 0 30px;
      color: var(--graphite);
      font-size: clamp(1.15rem, 2vw, 1.36rem);
    }
    .button-row { display: flex; flex-wrap: wrap; gap: 12px; }
    .button {
      min-height: 50px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 11px 18px;
      border: 1px solid var(--black);
      border-radius: 999px;
      font-weight: 800;
      text-decoration: none;
      cursor: pointer;
      transition: transform .2s ease, box-shadow .2s ease, background .2s ease;
    }
    .button:hover { transform: translateY(-2px); }
    .button--dark { color: var(--white); background: var(--black); }
    .button--light { color: var(--black); background: var(--white); }
    .button--orange { color: var(--black); border-color: var(--orange); background: var(--orange); }
    .button--orange:hover { box-shadow: 0 12px 30px rgba(248, 156, 73, .28); }
    .hero-card {
      position: relative;
      padding: 34px;
      border: 1px solid var(--black);
      border-radius: var(--radius);
      background: var(--white);
      box-shadow: 18px 18px 0 var(--orange-soft);
    }
    .hero-card::before {
      position: absolute;
      top: -1px;
      left: 34px;
      width: 82px;
      height: 8px;
      background: var(--orange);
      content: "";
    }
    .hero-card .label {
      margin: 0 0 24px;
      color: var(--orange-dark);
      font-size: .76rem;
      font-weight: 800;
      letter-spacing: .13em;
      text-transform: uppercase;
    }
    .hero-card h2 { margin: 0; font-size: 2rem; line-height: 1.05; letter-spacing: -.035em; }
    .hero-card p { margin: 14px 0 0; color: var(--muted); }
    .status-line {
      margin-top: 26px;
      padding-top: 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      border-top: 1px solid var(--line);
      font-weight: 700;
    }
    .status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 7px 10px;
      color: #7e3c08;
      background: var(--orange-soft);
      border-radius: 999px;
      font-size: .76rem;
      font-weight: 800;
      text-transform: uppercase;
    }
    .status::before { width: 8px; height: 8px; background: var(--orange); border-radius: 50%; content: ""; }
    .hero-meta {
      margin-top: 32px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px 22px;
      color: var(--muted);
      font-size: .88rem;
      font-weight: 700;
    }

    .identity-strip { border-block: 1px solid var(--line); background: var(--soft); }
    .identity-grid {
      min-height: 108px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      align-items: stretch;
    }
    .identity-item { padding: 24px 30px; border-left: 1px solid var(--line); }
    .identity-item:last-child { border-right: 1px solid var(--line); }
    .identity-item span {
      display: block;
      color: var(--orange-dark);
      font-size: .73rem;
      font-weight: 800;
      letter-spacing: .11em;
      text-transform: uppercase;
    }
    .identity-item strong { display: block; margin-top: 7px; font-size: 1.05rem; }

    .about-grid {
      display: grid;
      grid-template-columns: .85fr 1.15fr;
      gap: clamp(48px, 8vw, 110px);
      align-items: start;
    }
    .about-copy p { margin: 0 0 18px; color: var(--graphite); font-size: 1.08rem; }
    .about-copy .origin {
      margin-top: 28px;
      padding: 20px 22px;
      border-left: 5px solid var(--orange);
      background: var(--soft);
      color: var(--muted);
      font-size: .98rem;
    }
    .role-list { display: grid; gap: 12px; }
    .role {
      display: grid;
      grid-template-columns: 46px 1fr;
      gap: 18px;
      padding: 22px;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: var(--white);
    }
    .role-number {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      color: var(--black);
      background: var(--orange);
      border-radius: 50%;
      font-weight: 900;
    }
    .role h3 { margin: 0; font-size: 1.14rem; }
    .role p { margin: 5px 0 0; color: var(--muted); font-size: .95rem; }

    .vision-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-top: 42px;
    }
    .statement {
      min-height: 260px;
      padding: 34px;
      border-radius: var(--radius);
    }
    .statement--orange { background: var(--orange); }
    .statement--black { color: var(--white); background: var(--black); }
    .statement .number { font-size: .78rem; font-weight: 900; letter-spacing: .14em; text-transform: uppercase; }
    .statement h3 { margin: 64px 0 0; font-size: clamp(1.55rem, 3vw, 2.35rem); line-height: 1.14; letter-spacing: -.035em; }

    .work-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      margin-top: 42px;
    }
    .work-card {
      padding: 28px;
      border-top: 5px solid var(--orange);
      background: var(--white);
      box-shadow: var(--shadow);
    }
    .work-card svg { width: 32px; height: 32px; color: var(--orange-dark); }
    .work-card h3 { margin: 38px 0 9px; font-size: 1.27rem; }
    .work-card p { margin: 0; color: var(--muted); }

    .process {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      margin-top: 48px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      overflow: hidden;
    }
    .process-step {
      position: relative;
      min-height: 210px;
      padding: 26px;
      background: var(--white);
      border-right: 1px solid var(--line);
    }
    .process-step:last-child { border-right: 0; }
    .process-step .step { color: var(--orange-dark); font-size: 1.5rem; font-weight: 900; }
    .process-step h3 { margin: 42px 0 8px; font-size: 1.08rem; }
    .process-step p { margin: 0; color: var(--muted); font-size: .92rem; }

    .deliverables-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
      margin-top: 42px;
    }
    .deliverable {
      display: grid;
      grid-template-columns: 54px 1fr;
      gap: 20px;
      padding: 26px;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: var(--white);
    }
    .deliverable strong { color: var(--orange-dark); font-size: 1.8rem; line-height: 1; }
    .deliverable h3 { margin: 0; font-size: 1.15rem; }
    .deliverable p { margin: 6px 0 0; color: var(--muted); }

    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      margin-top: 46px;
    }
    .portfolio-card {
      position: relative;
      min-height: 330px;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      padding: 30px;
      text-align: left;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--white);
      cursor: pointer;
      overflow: hidden;
      transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
    }
    .portfolio-card::after {
      position: absolute;
      right: -48px;
      bottom: -48px;
      width: 145px;
      height: 145px;
      border: 30px solid var(--orange-soft);
      border-radius: 50%;
      content: "";
    }
    .portfolio-card:hover,
    .portfolio-card:focus-visible {
      transform: translateY(-6px);
      border-color: var(--orange);
      box-shadow: var(--shadow);
      outline: none;
    }
    .portfolio-card .kicker { color: var(--orange-dark); font-size: .75rem; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; }
    .portfolio-card h3 { margin: 76px 0 12px; font-size: 1.7rem; line-height: 1.05; letter-spacing: -.025em; }
    .portfolio-card p { margin: 0 0 26px; color: var(--muted); }
    .portfolio-card .open-label { margin-top: auto; font-weight: 900; }

    .ask-grid {
      display: grid;
      grid-template-columns: .82fr 1.18fr;
      gap: clamp(44px, 8vw, 100px);
      align-items: center;
    }
    .ask-panel {
      padding: 30px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--white);
      box-shadow: var(--shadow);
    }
    .chat-head { display: flex; align-items: center; justify-content: space-between; gap: 20px; padding-bottom: 18px; border-bottom: 1px solid var(--line); }
    .chat-title { display: flex; align-items: center; gap: 12px; }
    .chat-mark { width: 42px; height: 42px; display: grid; place-items: center; color: var(--black); background: var(--orange); border-radius: 50%; font-weight: 900; }
    .chat-head strong { display: block; }
    .chat-head span { color: var(--muted); font-size: .84rem; }
    .chat-body { min-height: 150px; padding: 24px 0; }
    .message {
      max-width: 88%;
      margin: 0;
      padding: 14px 16px;
      color: var(--graphite);
      background: var(--soft);
      border-radius: 4px 16px 16px 16px;
    }
    .chat-form { display: grid; grid-template-columns: 1fr auto; gap: 10px; }
    .chat-form input {
      min-width: 0;
      height: 50px;
      padding: 0 16px;
      border: 1px solid var(--line);
      border-radius: 999px;
      color: var(--black);
      background: var(--white);
    }
    .chat-form input:focus { border-color: var(--orange-dark); outline: 3px solid var(--orange-soft); }
    .chat-form button {
      width: 50px;
      height: 50px;
      border: 0;
      border-radius: 50%;
      color: var(--black);
      background: var(--orange);
      font-weight: 900;
      cursor: pointer;
    }
    .chat-note { margin: 12px 0 0; color: var(--muted); font-size: .78rem; }

    .cta { padding: 84px 0; background: var(--black); color: var(--white); }
    .cta-grid { display: grid; grid-template-columns: 1fr auto; gap: 40px; align-items: end; }
    .cta h2 { max-width: 760px; margin: 0; font-size: clamp(2.5rem, 5vw, 4.8rem); line-height: .96; letter-spacing: -.05em; }
    .cta h2 span { color: var(--orange); }
    .cta p { max-width: 650px; margin: 18px 0 0; color: #c9c9c9; font-size: 1.06rem; }

    .funding-note { padding: 26px 0; background: var(--orange-soft); border-bottom: 1px solid #f2d9c3; }
    .funding-note .container { display: grid; grid-template-columns: auto 1fr; gap: 16px; align-items: start; }
    .funding-note strong { color: var(--orange-dark); }
    .funding-note p { margin: 0; color: var(--graphite); font-size: .93rem; }

    .site-footer { padding: 40px 0; background: var(--white); }
    .footer-grid { display: flex; align-items: center; justify-content: space-between; gap: 30px; }
    .footer-logo { width: 132px; }
    .footer-copy { color: var(--muted); font-size: .86rem; text-align: right; }

    dialog {
      width: min(860px, calc(100% - 32px));
      max-height: min(86vh, 780px);
      padding: 0;
      border: 0;
      border-radius: 22px;
      color: var(--black);
      background: var(--white);
      box-shadow: 0 35px 100px rgba(0, 0, 0, .24);
    }
    dialog::backdrop { background: rgba(0, 0, 0, .64); backdrop-filter: blur(4px); }
    .dialog-inner { padding: 34px; overflow: auto; }
    .dialog-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 30px; padding-bottom: 20px; border-bottom: 1px solid var(--line); }
    .dialog-head h2 { margin: 4px 0 0; font-size: 2rem; line-height: 1.05; }
    .dialog-close { width: 42px; height: 42px; flex: 0 0 auto; border: 1px solid var(--line); border-radius: 50%; color: var(--black); background: var(--white); font-size: 1.35rem; cursor: pointer; }
    .dialog-copy { margin: 20px 0 0; color: var(--muted); }
    .concept-list { display: grid; gap: 10px; margin-top: 24px; }
    .concept {
      display: grid;
      grid-template-columns: 52px 1fr auto;
      gap: 16px;
      align-items: center;
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: 13px;
    }
    .concept.is-selected { border-color: var(--orange); background: var(--orange-soft); }
    .concept-index { width: 42px; height: 42px; display: grid; place-items: center; border-radius: 50%; background: var(--soft); font-weight: 900; }
    .concept.is-selected .concept-index { background: var(--orange); }
    .concept h3 { margin: 0; font-size: 1rem; }
    .tag { padding: 6px 9px; border-radius: 999px; color: var(--graphite); background: var(--soft); font-size: .7rem; font-weight: 900; text-transform: uppercase; white-space: nowrap; }
    .tag--selected { color: #693000; background: #ffd3ab; }
    .tag--future { color: #693000; background: var(--orange-soft); }
    .library-list { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 24px; }
    .library-item { padding: 20px; border: 1px solid var(--line); border-radius: 13px; }
    .library-item h3 { margin: 0; font-size: 1.05rem; }
    .library-item p { margin: 8px 0 0; color: var(--muted); font-size: .91rem; }
    .placeholder { margin-top: 24px; padding: 16px; color: var(--graphite); background: var(--soft); border-left: 5px solid var(--orange); }

    .reveal { opacity: 0; transform: translateY(18px); transition: opacity .55s ease, transform .55s ease; }
    .reveal.visible { opacity: 1; transform: none; }
    :focus-visible { outline: 3px solid rgba(216, 109, 19, .35); outline-offset: 3px; }

    @media (max-width: 960px) {
      .nav-links {
        position: absolute;
        inset: calc(100% + 1px) 20px auto;
        display: none;
        flex-direction: column;
        align-items: stretch;
        gap: 0;
        padding: 12px;
        border: 1px solid var(--line);
        border-radius: 14px;
        background: var(--white);
        box-shadow: var(--shadow);
      }
      .nav-links.open { display: flex; }
      .nav-links a { padding: 12px; }
      .nav-links a::after { display: none; }
      .menu-button { display: block; }
      .hero-grid, .about-grid, .ask-grid { grid-template-columns: 1fr; }
      .hero { min-height: auto; }
      .hero-grid { padding: 70px 0 84px; }
      .hero-card { max-width: 620px; }
      .work-grid, .portfolio-grid { grid-template-columns: 1fr; }
      .portfolio-card { min-height: 250px; }
      .portfolio-card h3 { margin-top: 45px; }
      .process { grid-template-columns: 1fr 1fr; }
      .process-step:nth-child(2) { border-right: 0; }
      .process-step:nth-child(-n+2) { border-bottom: 1px solid var(--line); }
      .cta-grid { grid-template-columns: 1fr; align-items: start; }
    }

    @media (max-width: 700px) {
      .container { width: min(var(--max), calc(100% - 28px)); }
      .section { padding: 68px 0; }
      .logo { width: 120px; }
      .hero h1 { font-size: clamp(3.25rem, 17vw, 5.2rem); }
      .identity-grid, .vision-grid, .deliverables-grid, .library-list { grid-template-columns: 1fr; }
      .identity-item, .identity-item:last-child { border: 0; border-bottom: 1px solid var(--line); }
      .statement { min-height: 235px; }
      .statement h3 { margin-top: 50px; }
      .process { grid-template-columns: 1fr; }
      .process-step, .process-step:nth-child(2) { min-height: 170px; border-right: 0; border-bottom: 1px solid var(--line); }
      .process-step:last-child { border-bottom: 0; }
      .process-step h3 { margin-top: 24px; }
      .concept { grid-template-columns: 44px 1fr; }
      .concept .tag { grid-column: 2; justify-self: start; }
      .footer-grid { align-items: flex-start; flex-direction: column; }
      .footer-copy { text-align: left; }
      .funding-note .container { grid-template-columns: 1fr; }
      .chat-form { grid-template-columns: 1fr auto; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { scroll-behavior: auto !important; transition-duration: .001ms !important; animation-duration: .001ms !important; }
      .reveal { opacity: 1; transform: none; }
    }
  </style>
</head>
<body>
  <a class="skip-link" href="#main">Skip to main content</a>

  <header class="site-header">
    <div class="container nav">
      <a class="logo-link" href="#top" aria-label="Geneva Health Forum — PIC home">
        <img class="logo" src="https://genevahealthforum.com/wp-content/uploads/2023/11/GHF_main_logo.png" alt="Geneva Health Forum">
      </a>
      <button class="menu-button" type="button" aria-expanded="false" aria-controls="main-navigation" aria-label="Open navigation">☰</button>
      <nav class="nav-links" id="main-navigation" aria-label="Main navigation">
        <a href="#about">Who we are</a>
        <a href="#vision">Vision</a>
        <a href="#work">What we do</a>
        <a href="#portfolio">Portfolio</a>
        <a href="#ask">Ask PIC</a>
        <a class="nav-action" href="#connect">Get involved</a>
      </nav>
    </div>
  </header>

  <main id="main">
    <section class="hero" id="top">
      <div class="container hero-grid">
        <div>
